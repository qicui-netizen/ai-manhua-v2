# 复制本文件为 .env.local 并填入你自己的 Key(.env.local 不会被 git 提交)
# 硅基流动 API Key(必填):https://cloud.siliconflow.cn 注册后在控制台创建
SILICONFLOW_API_KEY=

# 生图供应商:siliconflow(默认,Qwen-Image-Edit,约0.06-0.10元/格)
# 或 ark(火山方舟 Doubao-Seedream-4.5,约0.25元/格,角色一致性更强+原生出图比例)
# IMAGE_PROVIDER=siliconflow

# 火山方舟 API Key(IMAGE_PROVIDER=ark 时必填):https://console.volcengine.com/ark
# 注意:方舟 Key 可限定可调用的模型范围,开通 Seedream 后需确认 Key 已授权该模型
# ARK_API_KEY=
# ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# ARK_IMAGE_MODEL=doubao-seedream-4-5-251128

# 以下均为可选,不填使用默认值
# SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
# PLOT_STORYBOARD_MODEL=deepseek-ai/DeepSeek-V3
# IMAGE_EDIT_PROMPT_MODEL=deepseek-ai/DeepSeek-V3
# IMAGE_EDIT_MODEL=Qwen/Qwen-Image-Edit-2509
# MODERATION_VL_MODEL=Qwen/Qwen3-VL-8B-Instruct
